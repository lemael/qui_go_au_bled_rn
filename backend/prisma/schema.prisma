generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  transporter
  client
  both
  admin
}

enum AdStatus {
  active
  inactive
  expired
  pending
  rejected
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  password       String
  phone          String
  address        String
  photoUrl       String?
  role           UserRole @default(both)
  averageRating  Float    @default(0)
  totalReviews   Int      @default(0)
  fcmToken       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ads            TransportAd[]
  sentRequests   TransportRequest[] @relation("ClientRequests")
  ordersAsClient TransportOrder[]   @relation("ClientOrders")
  ordersAsTransporter TransportOrder[] @relation("TransporterOrders")
  reviewsReceived Review[]          @relation("TransporterReviews")
  reviewsGiven    Review[]          @relation("ClientReviews")
  notifications   Notification[]
}

model TransportAd {
  id                   String   @id @default(uuid())
  transporterId        String
  transporter          User     @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  departureCity        String
  arrivalCity          String
  flightDate           String
  flightTime           String
  maxWeightKg          Float
  pricePerKg           Float
  description          String
  status               AdStatus @default(active)
  totalPackagesCarried Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  requests TransportRequest[]
  orders   TransportOrder[]
}

model TransportRequest {
  id            String        @id @default(uuid())
  adId          String
  ad            TransportAd   @relation(fields: [adId], references: [id], onDelete: Cascade)
  transporterId String
  clientId      String
  client        User          @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  message       String?
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order TransportOrder?
}

model TransportOrder {
  id             String      @id @default(uuid())
  orderNumber    String      @unique @default(cuid())
  adId           String
  ad             TransportAd @relation(fields: [adId], references: [id])
  requestId      String      @unique
  request        TransportRequest @relation(fields: [requestId], references: [id])
  transporterId  String
  transporter    User        @relation("TransporterOrders", fields: [transporterId], references: [id])
  clientId       String
  client         User        @relation("ClientOrders", fields: [clientId], references: [id])
  departureCity  String
  arrivalCity    String
  flightDate     String
  pricePerKg     Float
  status         OrderStatus @default(PENDING)
  reviewAuthorized Boolean  @default(false)
  cancellationAuthorId   String?
  cancellationReason     String?
  cancelledAt            DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  reviews Review[]
}

model Review {
  id            String         @id @default(uuid())
  orderId       String
  order         TransportOrder @relation(fields: [orderId], references: [id])
  transporterId String
  transporter   User           @relation("TransporterReviews", fields: [transporterId], references: [id])
  clientId      String
  client        User           @relation("ClientReviews", fields: [clientId], references: [id])
  rating        Int
  comment       String
  createdAt     DateTime       @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
}
